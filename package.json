{
  "name": "desafio-backend-nodejs",
  "version": "1.0.0",
  "description": "Desafio técnico backend — Atendimento WhatsApp com IA (Meta + OpenAI)",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/infrastructure/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/infrastructure/db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "bullmq": "^5.0.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.0.0",
    "openai": "^4.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
